DEBUG=True
SECRET_KEY=django-insecure-dev-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Development mặc định dùng SQLite trong config.settings.dev.
USE_SQLITE=True

# Nếu muốn dùng PostgreSQL, đặt USE_SQLITE=False và cấu hình các biến dưới.
DB_ENGINE=django.db.backends.postgresql
DB_NAME=it_career_hub
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Development: email được in ra terminal.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@itcareerhub.local

# Khi cần gửi email thật, đổi EMAIL_BACKEND thành SMTP và điền các giá trị dưới.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
